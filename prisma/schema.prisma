// Japan Tour Booking Platform — Prisma Schema
// Prisma 7 · MySQL · Generated to app/generated/prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH (NextAuth v5 / Auth.js)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CUSTOMER)
  phone         String?
  nationality   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  messages      ChatMessage[]
  conversations ChatConversation[] @relation("CustomerConversations")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

// ─────────────────────────────────────────────
// TOURS
// ─────────────────────────────────────────────

model Tour {
  id               String         @id @default(cuid())
  slug             String         @unique
  title            String
  shortDescription String         @db.Text
  description      String         @db.LongText
  highlights       Json           // string[]
  includes         Json           // string[]
  excludes         Json           // string[]
  itinerary        Json           // { day: number; title: string; description: string }[]
  duration         Int            // days
  maxGroupSize     Int
  minGroupSize     Int            @default(1)
  meetingPoint     String
  endPoint         String?
  location         String
  prefecture       String?        // Tokyo, Kyoto, Osaka, etc.
  country          String         @default("Japan")
  category         TourCategory
  difficulty       TourDifficulty @default(MODERATE)
  languages        Json           // string[] — guide languages
  serviceProvider  String?        // plain text field, no login
  basePrice        Decimal        @db.Decimal(10, 2)
  childPrice       Decimal?       @db.Decimal(10, 2)
  status           TourStatus     @default(DRAFT)
  featured         Boolean        @default(false)
  rating           Decimal?       @db.Decimal(3, 2)
  reviewCount      Int            @default(0)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  images       TourImage[]
  availability TourAvailability[]
  bookings     Booking[]
  discounts    DiscountCode[]

  @@index([status, featured])
  @@index([slug])
  @@index([category])
}

enum TourCategory {
  CULTURAL
  ADVENTURE
  FOOD_AND_DRINK
  NATURE
  CITY_TOUR
  DAY_TRIP
  MULTI_DAY
  PRIVATE
  GROUP
}

enum TourDifficulty {
  EASY
  MODERATE
  CHALLENGING
}

enum TourStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model TourImage {
  id        String   @id @default(cuid())
  tourId    String
  url       String
  altText   String?
  order     Int      @default(0)
  isPrimary Boolean  @default(false)

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
}

model TourAvailability {
  id            String             @id @default(cuid())
  tourId        String
  date          DateTime           @db.Date
  startTime     String?            // "09:00"
  maxCapacity   Int
  bookedCount   Int                @default(0)
  priceOverride Decimal?           @db.Decimal(10, 2)
  status        AvailabilityStatus @default(AVAILABLE)

  tour     Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([tourId, date])
  @@index([tourId, status])
}

enum AvailabilityStatus {
  AVAILABLE
  FULL
  CLOSED
  CANCELLED
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id             String  @id @default(cuid())
  bookingRef     String  @unique // JPN-2024-001234
  tourId         String
  availabilityId String?
  customerId     String? // null = guest checkout

  // Guest info (for non-logged-in customers)
  guestName  String?
  guestEmail String
  guestPhone String?

  // Trip details
  tourDate        DateTime @db.Date
  numAdults       Int
  numChildren     Int      @default(0)
  specialRequests String?  @db.Text

  // Pricing
  subtotal       Decimal @db.Decimal(10, 2)
  discountAmount Decimal @db.Decimal(10, 2) @default(0)
  totalAmount    Decimal @db.Decimal(10, 2)
  currency       String  @default("USD")

  // Payment
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  stripeSessionId String?
  stripePaymentId String?
  bankTransferRef String?
  paidAt          DateTime?

  // Status
  status           BookingStatus @default(PENDING)
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  cancellationNote String?       @db.Text
  isManualEntry    Boolean       @default(false)
  adminNotes       String?       @db.Text

  discountCodeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tour         Tour              @relation(fields: [tourId], references: [id])
  availability TourAvailability? @relation(fields: [availabilityId], references: [id])
  customer     User?             @relation(fields: [customerId], references: [id])
  passengers   BookingPassenger[]
  discountCode DiscountCode?     @relation(fields: [discountCodeId], references: [id])
  conversation ChatConversation?

  @@index([tourId])
  @@index([customerId])
  @@index([status, paymentStatus])
  @@index([tourDate])
  @@index([guestEmail])
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  PAID
  REFUNDED
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model BookingPassenger {
  id          String    @id @default(cuid())
  bookingId   String
  firstName   String
  lastName    String
  nationality String?
  passportNo  String?
  dateOfBirth DateTime? @db.Date
  isLead      Boolean   @default(false)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

// ─────────────────────────────────────────────
// DISCOUNT CODES
// ─────────────────────────────────────────────

model DiscountCode {
  id               String       @id @default(cuid())
  code             String       @unique
  description      String?
  discountType     DiscountType
  discountValue    Decimal      @db.Decimal(10, 2)
  minBookingAmount Decimal?     @db.Decimal(10, 2)
  maxUses          Int?
  currentUses      Int          @default(0)
  validFrom        DateTime
  validUntil       DateTime?
  isActive         Boolean      @default(true)
  tourId           String?      // null = applies to all tours

  tour     Tour?     @relation(fields: [tourId], references: [id])
  bookings Booking[]

  createdAt DateTime @default(now())

  @@index([code, isActive])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

model ChatConversation {
  id           String             @id @default(cuid())
  type         ConversationType
  bookingId    String?            @unique
  customerId   String?
  visitorId    String?            // anonymous pre-booking visitor (socket ID or fingerprint)
  visitorName  String?
  visitorEmail String?
  status       ConversationStatus @default(OPEN)
  lastMessageAt DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  booking  Booking?      @relation(fields: [bookingId], references: [id])
  customer User?         @relation("CustomerConversations", fields: [customerId], references: [id])
  messages ChatMessage[]

  @@index([type, status])
  @@index([customerId])
}

enum ConversationType {
  BOOKING_SUPPORT // post-booking: admin <-> customer
  VISITOR_CS      // pre-booking: CS widget for site visitors
}

enum ConversationStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

model ChatMessage {
  id             String     @id @default(cuid())
  conversationId String
  senderId       String?    // null for anonymous visitors
  senderName     String
  senderRole     SenderRole
  content        String     @db.Text
  isRead         Boolean    @default(false)
  createdAt      DateTime   @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?            @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

enum SenderRole {
  ADMIN
  CUSTOMER
  VISITOR
}

// ─────────────────────────────────────────────
// EMAIL NOTIFICATIONS LOG
// ─────────────────────────────────────────────

model EmailLog {
  id         String      @id @default(cuid())
  to         String
  subject    String
  type       EmailType
  bookingId  String?
  status     EmailStatus @default(QUEUED)
  sentAt     DateTime?
  error      String?     @db.Text
  createdAt  DateTime    @default(now())

  @@index([bookingId])
  @@index([status])
}

enum EmailType {
  BOOKING_CONFIRMATION
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  MANUAL_PAYMENT_INSTRUCTIONS
  ADMIN_NEW_BOOKING
  ADMIN_NEW_MESSAGE
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}
